    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "image-size": "^2.0.2",
    "jotai": "^2.18.0",
    "lucide-react": "^0.575.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
